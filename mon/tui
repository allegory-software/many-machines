#!/usr/bin/env python3
"""mon tui — monitoring samples browser"""
import os, sys, tty, termios, select, shutil, signal
from pathlib import Path

SAMPLES = Path(__file__).parent / "samples"

# ── data ──────────────────────────────────────────────────────────────────────

def _int(p):          return int(p.read_text().strip())
def _int_or(p, d):    return _int(p) if p.exists() else d
def _oob(v, mn, mx):  return v < mn or v > mx

def scan_day(path, mn, mx):
    ts, vs, oob = [], [], False
    for line in path.read_bytes().replace(b"\x00", b"").decode().splitlines():
        parts = line.split()
        if len(parts) != 2: continue
        try:
            t, v = int(parts[0]), int(parts[1])
        except ValueError:
            continue
        ts.append(t); vs.append(v)
        if _oob(v, mn, mx): oob = True
    return ts, vs, oob

def load_topics():
    return sorted(p.name for p in SAMPLES.iterdir() if p.is_dir())

def load_days(topic):
    d = SAMPLES / topic
    mn, mx = _int(d / "min"), _int(d / "max")
    lo = _int_or(d / "lo", mn)
    hi = _int_or(d / "hi", mx)
    days = []
    for p in sorted(d.glob("*.sam"), key=lambda p: p.stem):
        _, _, oob = scan_day(p, mn, mx)
        days.append((p.stem, oob))
    return days, mn, mx, lo, hi

def graph_lines(topic, date, mn, mx, lo, hi, w, h):
    if hi <= lo: hi = lo + 1

    YW = 6
    pw = max(1, w - YW - 2)   # plot width (after "label│ ")
    ph = max(1, h - 3)         # plot height (title + plot + separator + x-axis = h)

    def to_col(x): return min(pw - 1, max(0, int(x / 24 * pw)))
    def to_row(v): return min(ph - 1, max(0, int((1 - (v - lo) / (hi - lo)) * ph)))

    cells = {}  # (row, col) -> (char, ansi_color)

    ts, vs, _ = scan_day(SAMPLES / topic / f"{date}.sam", mn, mx)
    for t, v in zip(ts, vs):
        color = '\033[31m' if _oob(v, mn, mx) else '\033[37m'
        cells[to_row(v), to_col(t / 3600)] = ('·', color)

    out = []
    out.append(f"{topic}  {date}   [{mn} – {mx}]"[:w])

    for r in range(ph):
        v_at = round(lo + (1 - r / (ph - 1 or 1)) * (hi - lo))
        lbl = f"{str(v_at):>{YW}.{YW}}"
        row = []
        for c in range(pw):
            ch, col = cells.get((r, c), (' ', ''))
            row.append(f"{col}{ch}\033[0m" if col else ch)
        out.append(lbl + '│' + ''.join(row))

    out.append(' ' * YW + '└' + '─' * pw)

    x_row = [' '] * pw
    for hour in range(0, 25, 2):
        c = to_col(hour)
        lbl = str(hour)
        c = max(0, c - len(lbl) + 1)
        for i, ch in enumerate(lbl):
            if c + i < pw: x_row[c + i] = ch
    out.append(' ' * (YW + 1) + ''.join(x_row))

    return out

# ── terminal ──────────────────────────────────────────────────────────────────

def tsize():        return shutil.get_terminal_size()
def at(r, c):       return f"\033[{r};{c}H"
def rev(s):         return f"\033[7m{s}\033[0m"
def red(s):         return f"\033[91m{s}\033[0m"
def bold(s):        return f"\033[1m{s}\033[0m"

def read_key():
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        try:
            ch = os.read(fd, 1).decode("utf-8", errors="replace")
        except InterruptedError:
            return ""
        if ch == "\x1b":
            r, _, _ = select.select([fd], [], [], 0.05)
            if r: ch += os.read(fd, 6).decode("utf-8", errors="replace")
        return ch
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)

# ── draw ──────────────────────────────────────────────────────────────────────

TW, DW = 22, 16   # topic / day column widths

def draw(topics, ti, days, mn, mx, lo, hi, di, pane, cache=None):
    cols, rows = tsize()
    gx  = TW + DW + 3          # graph start col (1-based)
    gw  = max(20, cols - gx)
    gh  = max(5,  rows - 3)
    out = ["\033[H\033[2J\033[?25l"]

    # topic list
    for i, name in enumerate(topics):
        if i >= rows - 2: break
        label = f"{name:{TW-1}.{TW-1}}"
        tdays = cache[name][0] if cache else days if i == ti else []
        is_red = tdays and tdays[-1][1]
        if is_red: label = red(label)
        out.append(at(i + 2, 1) + (rev(label) if i == ti and pane == 0
                                    else bold(label) if i == ti and not is_red
                                    else label))

    # day list
    for i, (date, oob) in enumerate(days):
        if i >= rows - 2: break
        label = f"{date + (' ●' if oob else ''):{DW-1}.{DW-1}}"
        label = red(label) if oob else label
        out.append(at(i + 2, TW + 2) + (rev(label) if i == di and pane == 1
                                          else bold(label) if i == di and not oob
                                          else label))

    # graph
    date = days[di][0]
    for i, line in enumerate(graph_lines(topics[ti], date, mn, mx, lo, hi, gw, gh)):
        if i >= rows - 2: break
        out.append(at(i + 2, gx) + line + "\033[0m")

    # status bar
    bar = f" {topics[ti]}  [{mn}–{mx}]  ↑↓:navigate  ←→/enter:switch pane  q:quit "
    out.append(at(rows, 1) + f"\033[7m{bar:{cols}.{cols}}\033[0m")

    sys.stdout.write("".join(out))
    sys.stdout.flush()

# ── main loop ─────────────────────────────────────────────────────────────────

def main():
    topics  = load_topics()
    cache   = {t: load_days(t) for t in topics}

    signal.signal(signal.SIGWINCH, lambda *_: None)  # wake read_key on resize

    ti, di, pane = 0, -1, 0

    sys.stdout.write("\033[?1049h")  # enter alt screen
    try:
        while True:
            days, mn, mx, lo, hi = cache[topics[ti]]
            n = len(days)
            if not n: continue
            if di < 0 or di >= n: di = n - 1

            draw(topics, ti, days, mn, mx, lo, hi, di, pane, cache)

            key = read_key()
            if   key in ("q", "\x03"):                          break
            elif key in ("\x1b[A", "k"):                        # up
                if pane == 0: ti = max(0, ti - 1); di = -1
                else:         di = max(0, di - 1)
            elif key in ("\x1b[B", "j"):                        # down
                if pane == 0: ti = min(len(topics) - 1, ti + 1); di = -1
                else:         di = min(n - 1, di + 1)
            elif key in ("\x1b[C", "\r", "\n", " ", "l"):      # right / enter
                pane = 1
            elif key in ("\x1b[D", "h"):                        # left
                pane = 0
    finally:
        sys.stdout.write("\033[?25h\033[?1049l")  # restore screen
        sys.stdout.flush()

if __name__ == "__main__":
    main()
