#!/bin/bash
#
# MM MON: Continuous Monitoring Service
# Written by Cosmin Apreutesei. Public Domain.
#
# mon start|stop|restart|[-q] status    manage daemon
# mon reset                             reset alerts
# mon clear-samples                     clear sample history
# mon pause | resume|unpause            pause/resume sampling
# mon install                           run `mm . install mon`

set -o pipefail

[[ $EUID == 0 ]] || exec sudo -E "$0" "$@"

# utils ----------------------------------------------------------------------

die()  { printf "%s\n" "$*" >&2; exit 1; }
say()  { printf "%s\n" "$*" >&2; }
must() { "$@" || die "$* [failed]"; }

catfile() { # FILE -> R1 (no subprocess)
	IFS= read -r -d '' R1 < "$1"
	R1=${R1%$'\n'}
}

timeago() { # EPOCH -> R1
	local d=$(( $(date +%s) - $1 ))
	if   ((d < 120      )); then R1="$d seconds ago"
	elif ((d < 7200     )); then R1="$((d/60)) minutes ago"
	elif ((d < 172800   )); then R1="$((d/3600)) hours ago"
	elif ((d < 5184000  )); then R1="$((d/86400)) days ago"
	elif ((d < 63072000 )); then R1="$((d/2592000)) months ago"
	else                         R1="$((d/31536000)) years ago"
	fi
}

# init -----------------------------------------------------------------------

[[ $EUID == 0 ]] || die "Must be root."
must cd "${0%mon}"

# config ---------------------------------------------------------------------

NTFY_URL=  # set it or you won't get notifications!
SMARTCTL=/usr/sbin/smartctl
MACHINE=$(hostname -s)
PROBING_INTERVAL=60
ALERT_COOLDOWN=3600  # suppress re-alerts within this many seconds (trickle suppressor)
MAX_CPU=90
MAXT_CPU=3
MIN_FREE_RAM_MB=1024
MAXT_RAM=3
MIN_FREE_DISK_MB=4096
UPS_VA=600
UPS_LOAD_HI=200
SERVICES_BLACKLIST=(
	mon mm-mon
	anacron avahi-daemon cups cups-browsed e2scrub_reap
	grub-common irqbalance lm-sensors
	ModemManager NetworkManager 'NetworkManager-*'
	console-setup keyboard-setup remote-fs
	'systemd-*' 'dbus-*' wpa_supplicant
	apparmor 'plymouth-*' smartd smartmontools
	display-manager apcupsd exim4 autorandr-lid-listener
)

[[ -f mon.conf ]] && . mon.conf

# parse cmdline & damonize ---------------------------------------------------

must mkdir -p alerts notified samples

mon_pid() { pgrep -f 'bin/bash.*mon/mon daemon'; }

RUN=
if [[ -f .systemd && $1 =~ ^(start|stop|restart|status)$ ]]; then
	systemctl $1 mm-mon
elif [[ -f .systemd && $1 == -q && $2 == status ]]; then
	systemctl is-active -q mm-mon
elif [[ $1 == start ]]; then
	pid=`mon_pid` && die "Already running. PID: $pid"
	nohup "$0" daemon >/dev/null 2> mon.log &
elif [[ $1 == stop ]]; then
	pid=`mon_pid` || die "Not running."
	kill $pid
	while kill -0 $pid 2>/dev/null; do sleep 0.1; done
elif [[ $1 == restart ]]; then
	"$0" stop
	"$0" start
elif [[ $1 == status ]]; then
	pid=`mon_pid`; x=$?
	[[ $2 == -q ]] || { [[ $x == 0 ]] && say "Running. PID: $pid" || say "Not running."; }
	exit $x
elif [[ $1 == reset ]]; then
	find alerts notified -mindepth 1 -delete
elif [[ $1 == pause ]]; then
	touch paused
elif [[ $1 == resume || $1 == unpause ]]; then
	rm -f paused
elif [[ $1 == clear-samples ]]; then
	[[ $2 == please ]] || die "Say please."
	rm -rf samples
elif [[ $1 == daemon || $1 == systemd ]]; then
	RUN=1
	DAEMON=1
elif [[ $1 == install ]]; then
	mm . install mon
elif [[ $1 ]]; then
	die "Invalid arg: $1"
else
	RUN=1
fi
[[ $RUN ]] || exit 0

# sample logging & alerts ----------------------------------------------------

# change the log file when today becomes tomorrow.
set_file() {
	T0=`date -d '00:00' +%s`
	T1=`date -d 'tomorrow 00:00' +%s`
	FILE=`date +%F`
}
set_file

# count consecutive times when value was out of range.
# we only report values that were out of range more than MAXT times.
declare -A COUNTS # k->n

log() { # K= V= LO= HI= MIN= MAX= [MAXT=] T= T0= DIR= FILE=
	[[ $V ]] || return

	# log the value in samples file to show in a graph
	[[ $DAEMON ]] && {
		local lo=${LO:-$MIN} hi=${HI:-$MAX}
		if [[ -d samples/$K ]]; then
			# archive if lo/hi changed (e.g. RAM/disk upgrade)
			local old_lo old_hi
			IFS= read -r old_lo < samples/$K/lo
			IFS= read -r old_hi < samples/$K/hi
			if [[ $old_lo != $lo || $old_hi != $hi ]]; then
				mv samples/$K samples/${K}-${old_lo}-${old_hi}
			fi
		fi
		[[ -d samples/$K ]] || {
			must mkdir -p samples/$K
			printf "%d\n" $lo  > samples/$K/lo
			printf "%d\n" $hi  > samples/$K/hi
			printf "%d\n" $MIN > samples/$K/min
			printf "%d\n" $MAX > samples/$K/max
		}
		printf "%05d %s\n" $((T - T0)) $V >> samples/$K/$FILE.sam
	}

	# check alert thresholds
	local ALERT
	if ((V < MIN || V > MAX)); then
		((COUNTS[$K]++))
		local C=${COUNTS[$K]}
		local MAXT=${MAXT:-1}
		if ((C == MAXT)); then
			ALERT=!  # only on episode start, not every tick
		fi
	else
		COUNTS[$K]=0
	fi

	# show the value when running mon in foreground.
	printf "%25s %1s %s\n" $K "$ALERT" $V

	# record alert on episode start only (mtime = episode start time, not last tick)
	[[ $DAEMON && $ALERT ]] && {
		local file=alerts/$K
		printf "%s\n" $V > $file
	}
}

notify() {
	[[ $DAEMON ]] || return
	[[ $NTFY_URL ]] || return
	local now; now=$(date +%s)
	must pushd alerts >/dev/null
	local f s
	for f in `find -maxdepth 1 -type f -printf '%f\n'`; do
		local alert_mtime; alert_mtime=$(stat -c %Y $f)
		local notified=../notified/$f
		if [[ -f $notified ]]; then
			local notified_mtime; notified_mtime=$(stat -c %Y $notified)
			# suppress if no new episode since last notify, or cooldown hasn't elapsed
			(( alert_mtime <= notified_mtime )) && continue
			(( notified_mtime >= now - ALERT_COOLDOWN )) && continue
		fi
		touch $notified  # record time of this notification
		local t; timeago $alert_mtime; t=$R1
		catfile $f; local v=$R1
		s="$s$f: $v ($t)"$'\n'
	done
	must popd
	[[ $s ]] || return
	curl -s -d "$s" -H "Tags: warning" -H "Title: MON @ $MACHINE ALERT" "$NTFY_URL" >/dev/null
}

# probing modules ------------------------------------------------------------

is_running() {
	local p=/sys/fs/cgroup/system.slice/$1.service/cgroup.procs
	[[ -e $p ]] && IFS= read -r _ < "$p"
}

RAM_MB=`cat /proc/meminfo | awk '/MemTotal/ {print int($2/1024)}'`
probe_ram() {
	local free=`cat /proc/meminfo | awk '/MemAvailable/ {print int($2/1024)}'`
	local used=$((RAM_MB - free))
	K=RAM V=$used LO=0 HI=$RAM_MB MIN=0 MAX=$((RAM_MB - MIN_FREE_RAM_MB)) MAXT=$MAXT_RAM log
}

probe_disks() {
	local name fstype mount label size avail
	while read name fstype mount label; do
		[[ $mount ]] || continue
		[[ $mount == /boot/efi ]] && continue
		case $fstype in ext4|xfs|btrfs|zfs) ;; *) continue;; esac
		[[ $mount == / ]] && label=root
		[[ $label ]] || label=`basename $mount`
		read size avail < <(df -m --output=size,avail $mount | tail -n1)
		local used=$((size - avail))
		local minvar="MIN_FREE_${label^^}_MB"; local minfree=${!minvar}
		minfree=${minfree:-$MIN_FREE_DISK_MB}
		K=DISK-$label V=$used LO=0 HI=$size MIN=0 MAX=$((size - minfree)) log
	done < <(lsblk -ln -o NAME,FSTYPE,MOUNTPOINT,LABEL)
}

unset CPU_STATS1
unset CPU_STATS2
probe_cpu() {
	CPU_STATS2=()
	local line
	while IFS= read -r line; do
		[[ $line == cpu[0-9]* ]] && CPU_STATS2+=("$line")
	done < /proc/stat

	if declare -p CPU_STATS1 &>/dev/null; then # we have at least 2 samples
		local i
		for i in "${!CPU_STATS1[@]}"; do # go through all cpu cores
			local -a f1; read -a f1 <<<"${CPU_STATS1[i]}"
			local -a f2; read -a f2 <<<"${CPU_STATS2[i]}"

			local idle1=${f1[4]}
			local idle2=${f2[4]}

			local total1=0 total2=0
			local n; for n in "${f1[@]:1}"; do ((total1+=n)); done
			local n; for n in "${f2[@]:1}"; do ((total2+=n)); done

			local total=$((total2 - total1))
			local idle=$((idle2 - idle1))
			local usage=$((100 * (total - idle) / total))
			K=CPU$i V=$usage LO=0 HI=100 MIN=0 MAX=$MAX_CPU MAXT=$MAXT_CPU log
		done
	fi
	CPU_STATS1=("${CPU_STATS2[@]}")
}

declare -A RESTART_COUNTS  # previous values

probe_services() {
	declare -A seen
	local f
	for f in /etc/systemd/system/multi-user.target.wants/*.service \
	         /etc/systemd/system/*.service; do

		# filter services
		[[ -e $f ]] || continue
		local name=`basename "$f" .service`
		local canonical=`basename "$(realpath "$f")" .service`
		[[ ${seen[$canonical]} ]] && continue; seen[$canonical]=1
		local pat skip=
		for pat in "${SERVICES_BLACKLIST[@]}"; do
			[[ $name == $pat ]] && { skip=1; break; }
		done
		[[ $skip ]] && continue

		# log running status
		local V; is_running "$canonical" && V=1 || V=0
		K=service-$name LO=0 HI=1 MIN=1 MAX=1 log

		# log crash counts
		local count=$(systemctl show $name --property=NRestarts --value)
		local prev=${RESTART_COUNTS[$name]:-$count}  # init to current on first run
		local delta=$((count - prev))
		RESTART_COUNTS[$name]=$count
		K=crashes-$name V=$delta LO=0 HI=10 MIN=0 MAX=0 log
	done
}

probe_ups_apc() { # -> BATTERY_CHARGE LINE_VOLTAGE UPS_LOAD
	local k v
	local PF=70 # 100x scale
	while IFS=: read -r k v; do
		[[ $k == BCHARGE* ]] && BATTERY_CHARGE=${v%%.*}
		[[ $k == LINEV*   ]] && LINE_VOLTAGE=${v%%.*}
		[[ $k == LOADPCT* ]] && {
			UPS_LOAD=${v%%.*}
			UPS_LOAD=$((UPS_VA * PF * UPS_LOAD / 10000)) # in watts
		}
	done < <(timeout 3 apcaccess status 2>/dev/null)
}

probe_ups() {
	command -v apcaccess >/dev/null || return
	local BATTERY_CHARGE LINE_VOLTAGE UPS_LOAD
	probe_ups_apc
	K=UPS_BATTERY_CHARGE V=$BATTERY_CHARGE LO=0   HI=100          MIN=50  MAX=100 log
	K=UPS_LINE_VOLTAGE   V=$LINE_VOLTAGE   LO=190 HI=270          MIN=207 MAX=253 log
	K=UPS_LOAD           V=$UPS_LOAD       LO=0   HI=$UPS_LOAD_HI MIN=0   MAX=200 log
}

probe_temps() {
	local n
	local -A seen
	for n in `ls /sys/class/hwmon`; do
		[[ -f /sys/class/hwmon/$n/temp1_input ]] || continue
		catfile /sys/class/hwmon/$n/name; local name=$R1
		catfile /sys/class/hwmon/$n/temp1_input; V=$((R1 / 1000))
		[[ $name == acpitz ]] && continue # fake
		[[ $name == spd5118 ]] && name=ram
		[[ $name == coretemp ]] && name=cpu
		local i=${seen[$name]:-1}
		seen[$name]=$((i + 1))
		local suffix; ((i > 1)) && suffix=$i || true
		K=TEMP-$name$suffix LO=0 HI=100 MIN=20 MAX=70 log
	done
}

probe_smart() {
	[[ -x $SMARTCTL ]] || return

	local dev name warn spare used errs realloc pending

	for dev in /sys/class/nvme/nvme*; do
		[[ -d $dev ]] || continue
		name=$(basename "$dev")
		read -r warn spare used errs < <(
			timeout 3 $SMARTCTL -a -j /dev/$name | \
			jq -r '[
				.nvme_smart_health_information_log.critical_warning // 0,
				.nvme_smart_health_information_log.available_spare  // 0,
				.nvme_smart_health_information_log.percentage_used  // 0,
				.nvme_smart_health_information_log.media_errors     // 0
			] | @tsv'
		)
		[[ $warn ]] || continue
		K=${name}-warn   V=$warn  LO=0 HI=255 MIN=0  MAX=0   log # bitmask of serious health issues
		K=${name}-spare  V=$spare LO=0 HI=100 MIN=10 MAX=100 log # drive is near EOL if < 10
		K=${name}-wear   V=$used  LO=0 HI=100 MIN=0  MAX=80  log # lifespan indicator
		K=${name}-errors V=$errs  LO=0 HI=10  MIN=0  MAX=0   log # data loss events
	done

	for dev in /sys/block/sd[a-z]; do
		[[ -d $dev ]] || continue
		name=$(basename "$dev")
		read -r realloc pending < <(
			timeout 3 $SMARTCTL -a -j /dev/$name | \
			jq -r '[
				(.ata_smart_attributes.table // [] | map(select(.id==5))   | first | .raw.value // 0),
				(.ata_smart_attributes.table // [] | map(select(.id==197)) | first | .raw.value // 0)
			] | @tsv'
		)
		[[ $realloc ]] || continue
		K=${name}-realloc V=$realloc LO=0 HI=100 MIN=0 MAX=0 log # reallocated sectors
		K=${name}-pending V=$pending LO=0 HI=100 MIN=0 MAX=0 log # pending sectors
	done
}

probe_reboot_required() {
	# running kernel != latest installed (per /vmlinuz symlink, kept current
	# by linux-image postinst). Catches kernel security updates like Dirty Frag.
	local V=0
	local target=$(readlink /vmlinuz 2>/dev/null)
	[[ -n $target && ${target##*/vmlinuz-} != $(uname -r) ]] && V=1
	K=reboot-required V=$V LO=0 HI=1 MIN=0 MAX=0 log
}

probe_ssl_expired() {
	local dir
	for dir in /root/.acme.sh.etc/*/; do
		[[ -d $dir ]] || continue
		local cert=${dir}fullchain.cer
		[[ -f $cert ]] || continue
		local domain
		domain=$(basename "$dir")
		[[ $domain == ca ]] && continue
		local exp_date
		exp_date=$(openssl x509 -enddate -noout -in "$cert" 2>/dev/null) || continue
		exp_date=${exp_date#notAfter=}
		local exp_epoch
		exp_epoch=$(date -d "$exp_date" +%s) || continue
		local days=$(( (exp_epoch - $(date +%s)) / 86400 ))
		K=ssl-$domain V=$days LO=0 HI=90 MIN=14 MAX=3650 log
	done
}

probe_forced_reboot() {
	local btime_file=.boot_time
	local btime=$(awk '/^btime / {print $2}' /proc/stat)
	local prev_btime
	[[ -f $btime_file ]] && IFS= read -r prev_btime < $btime_file
	printf "%d\n" $btime > $btime_file
	local V=0
	if [[ $prev_btime && $prev_btime != $btime ]]; then
		# machine rebooted — check if previous boot ended cleanly
		journalctl -b -1 --no-pager -q 2>/dev/null \
			| grep -q "systemd-reboot\|systemd-poweroff\|systemd-halt" || V=1
	fi
	K=forced-reboot V=$V LO=0 HI=1 MIN=0 MAX=0 log
}

# main loop ------------------------------------------------------------------

[[ $NTFY_URL ]] || say "NTFY_URL not set. Notifications are disabled."
[[ $SMARTCTL ]] || say "smartctl not found. SSD health will not be monitored."
command -v apcaccess >/dev/null || say "apcaccess not found. UPS state will not be monitored."

# trap Ctrl+C to stop the loop cleanly.
STOP=
trap 'STOP=1' SIGTERM SIGINT

TICK=0
every() { (( TICK % $1 == 0 )); } # true every N ticks
# the `sleep & wait` is because SIGTERM won't reach sleep which causes
# `systemctl stop` to hang. yay bash.
next_tick() { sleep $PROBING_INTERVAL & wait; }

[[ $DAEMON ]] && say "Started."
while [[ ! $STOP ]]; do
	((TICK++)) || true

	[[ -f paused ]] && {
		next_tick
		continue
	}

	echo

	T=`date +%s`
	((T1 > T)) || set_file

	printf "%15s %1s %s\n" @ "" "$(date '+%F %T')"

	probe_cpu
	probe_ram
	probe_temps
	probe_services
	probe_forced_reboot
	probe_ups
	probe_disks
	every 60 && probe_smart
	every 60 && probe_reboot_required
	every 60 && probe_ssl_expired

	echo

	notify

	next_tick
done
say "Stopped."
